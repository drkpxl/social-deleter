{
  "_note": "VERIFIED against live bsky.app (logged in) via DOM inspection: item roots are data-testid=\"feedItem-by-<handle>\"; profile tabs are CLIENT-SIDE (the URL never changes) and are reached by clicking [role=\"tab\"]:has([data-testid=\"profilePager-<Label>\"]); posts/reposts/likes deletion controls confirmed working. Bluesky has NO <time datetime> \u2014 the date lives in the permalink anchor's data-tooltip/aria-label as prose (e.g. \"July 19, 2026 at 4:56 PM\"). Unverified: undoRepostMenuItem's exact testid (menu-only).",
  "schemaVersion": 2,
  "selectors": {
    "postItem": "div[data-testid^=\"feedItem\"]",
    "repostItem": "div[data-testid^=\"feedItem\"]",
    "replyItem": "div[data-testid^=\"feedItem\"]",
    "likeItem": "div[data-testid^=\"feedItem\"]",
    "menuButton": "[data-testid=\"postDropdownBtn\"], [aria-label=\"Open post options menu\"]",
    "deleteMenuItem": "[data-testid=\"postDropdownDeleteBtn\"]",
    "deleteConfirm": "[data-testid=\"confirmBtn\"]",
    "unlikeButton": "[data-testid=\"likeBtn\"]",
    "repostIndicator": "[data-testid=\"feedItem-repostedBy\"], a[href*=\"/profile/\"][aria-label*=\"Reposted\" i], a[aria-label*=\"Reposted by\" i]",
    "repostButton": "[data-testid=\"repostBtn\"]",
    "undoRepostMenuItem": "[data-testid=\"repostDropdownUndoBtn\"], [role=\"menuitem\"][aria-label*=\"Undo repost\" i], [data-testid=\"repostDropdownRepostBtn\"]",
    "itemTimestamp": "a[href*=\"/post/\"][data-tooltip], a[href*=\"/post/\"][aria-label], time[datetime]",
    "tabPosts": "[role=\"tab\"]:has([data-testid=\"profilePager-Posts\"])",
    "tabReplies": "[role=\"tab\"]:has([data-testid=\"profilePager-Replies\"])",
    "tabLikes": "[role=\"tab\"]:has([data-testid=\"profilePager-Likes\"])"
  }
